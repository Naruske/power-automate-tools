{
   "name": "Power Automate Tools (New Designer Support)",
   "description": "This extension enables editing a Power Automate flow definition as JSON. Now supports the v3 New Designer.",
   "version": "1.3",
   "manifest_version": 3,
   "icons": {
      "512": "icons/pa-tools-512.png",
      "256": "icons/pa-tools-256.png",
      "128": "icons/pa-tools-128.png",
      "48": "icons/pa-tools-48.png"
   },
   "permissions": [
      "activeTab",
      "webRequest",
      "tabs"
   ],
   "host_permissions": [
      "https://api.flow.microsoft.com/*",
      "*://*.flow.microsoft.com/",
      "*://*.make.powerautomate.com/",
      "*://*.make.powerapps.com/",
      "*://*.api.powerautomate.com/*",
      "https://api.powerautomate.com/*",
      "*://*.environment.api.powerplatform.com/*",
      "https://login.microsoftonline.com/"
   ],
   "action": {
      "default_title": "Power Automate Tools (New Designer Support)"
   },
   "background": {
      "service_worker": "background.js"
   }
}